# Sulap Artisan — environment template
# Copy to `.env` and fill in real values. `.env` is gitignored and must NEVER
# be committed. Only VITE_-prefixed vars are exposed to the browser bundle, so
# ONLY put the Supabase *anon/public* key here — never the service_role key
# (it bypasses RLS and must live server-side only, e.g. in a Netlify Function
# env var, never in this file or any client bundle).

# Phase 2 (Supabase) — not wired yet. These are the vars the client will read.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
